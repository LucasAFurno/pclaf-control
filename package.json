{
  "name": "pclaf-control",
  "version": "0.0.0",
  "private": true,
  "description": "Sistema comercial web para PCLAF Control.",
  "author": "PCLAF",
  "main": "desktop/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs prod",
    "build:prod": "node scripts/build.mjs prod",
    "build:dev": "node scripts/build.mjs dev",
    "preview": "vite preview",
    "test:notifications": "node fiscal-server/scripts/notify-discord.mjs",
    "notify:deploy": "node fiscal-server/scripts/notify-deploy.mjs",
    "backup:postgres": "node fiscal-server/scripts/backup-postgres.mjs",
    "notify:summary": "node fiscal-server/scripts/notify-summary.mjs",
    "desktop:start": "npm run build && electron desktop/main.mjs",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "pg": "^8.16.3",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.pclaf.control",
    "productName": "PCLAF Control",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
