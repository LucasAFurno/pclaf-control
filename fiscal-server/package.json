{
  "name": "pclaf-fiscal-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servicio privado de facturacion ARCA para PCLAF Control.",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.mjs",
    "start": "node --env-file=.env src/server.mjs",
    "test": "node --test",
    "test:notifications": "node scripts/notify-discord.mjs",
    "notify:deploy": "node scripts/notify-deploy.mjs",
    "backup:postgres": "node scripts/backup-postgres.mjs",
    "notify:summary": "node scripts/notify-summary.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google-cloud/storage": "7.21.0"
  }
}
