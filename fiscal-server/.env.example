# Nunca uses los valores de ejemplo en produccion.
NODE_ENV=development
PORT=8787
FISCAL_HOST=127.0.0.1
FISCAL_SERVICE_TOKEN=reemplazar-por-un-token-aleatorio-largo
# Base64 de 32 bytes. Ejemplo: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FISCAL_MASTER_KEY_BASE64=reemplazar-por-una-clave-aes-256
FISCAL_DATA_DIR=.fiscal-data
# filesystem es exclusivo de desarrollo. En Cloud Run usar supabase.
FISCAL_STORE=filesystem
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FISCAL_OPENSSL_BIN=openssl
# homologacion | production
ARCA_ENVIRONMENT=homologacion
ARCA_TIMEOUT_MS=15000
ARCA_ATTEMPT_TIMEOUT_MS=4500
ARCA_MAX_ATTEMPTS=2
ARCA_CIRCUIT_FAILURE_THRESHOLD=3
ARCA_CIRCUIT_COOLDOWN_MS=60000
FISCAL_RATE_WINDOW_MS=60000
FISCAL_GLOBAL_RATE_PER_WINDOW=60
FISCAL_TENANT_RATE_PER_WINDOW=15
FISCAL_INVOICE_RATE_PER_WINDOW=6
FISCAL_EMERGENCY_STOP_CACHE_MS=5000
# Debe superar el timeout de Cloud Run para recuperar pending sin duplicar envios.
FISCAL_PROCESSING_LEASE_SECONDS=50
# Notificaciones PCLAF Control. Las URLs son secretos y nunca deben publicarse.
PCLAF_CONTROL_DISCORD_ENABLED=false
PCLAF_CONTROL_DISCORD_GENERAL_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_LOGS_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_ALERTAS_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_ARCA_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_SEGURIDAD_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_BACKUPS_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_DEPLOYS_WEBHOOK_URL=
PCLAF_CONTROL_DISCORD_RESUMEN_WEBHOOK_URL=
PCLAF_CONTROL_TELEGRAM_ENABLED=false
PCLAF_CONTROL_TELEGRAM_BOT_TOKEN=
PCLAF_CONTROL_TELEGRAM_CHAT_ID=
# Backup local/externo: no usar una contraseña visible en argumentos.
BACKUP_DATABASE_URL=
BACKUP_OUTPUT_DIR=backups
BACKUP_GCS_BUCKET=
BACKUP_GCS_PREFIX=pclaf-control/backups
BACKUP_RETENTION_DAYS=30
